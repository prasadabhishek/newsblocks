# NewsBlocks Local Runner
# Required for GitHub push (or set up SSH keys)
GITHUB_TOKEN=ghp_your_token_here

# Optional: How often to run (in hours, default: 4)
RUN_INTERVAL_H=4

# AI Settings
AI_PROVIDER=ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma3:4b  # Default: gemma3:4b (fast, accurate) - alternatives: llama3:8b, qwen3:4b
